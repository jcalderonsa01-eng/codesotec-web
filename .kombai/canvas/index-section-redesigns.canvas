      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&display=swap');\n</style>\n\n<section class=\"relative isolate overflow-hidden bg-[#050505] text-white antialiased border-t border-[rgba(255,255,255,0.06)]\" style=\"font-family:Inter,system-ui,-apple-system,sans-serif\" data-kid=\"1\">\n  \n  <div class=\"pointer-events-none absolute inset-x-0 top-0 h-px bg-[linear-gradient(90deg,transparent,rgba(255,255,255,0.14),transparent)]\" data-kid=\"2\"></div>\n\n  <div class=\"relative max-w-[1320px] mx-auto px-6 md:px-12 py-24 md:py-32\" data-kid=\"3\">\n    <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16\" data-kid=\"4\">\n\n      \n      <div class=\"signal-head relative lg:col-span-5 lg:sticky lg:top-24 self-start\" data-kid=\"5\">\n        \n        <div class=\"head-glow pointer-events-none absolute -top-28 -left-20 w-[420px] h-[420px] rounded-full opacity-50 blur-[95px] -z-10\" style=\"background:radial-gradient(circle at 32% 30%,rgba(34,171,207,0.55),transparent 62%),radial-gradient(circle at 72% 70%,rgba(160,119,240,0.45),transparent 62%)\" data-kid=\"6\"></div>\n\n        <div class=\"head-fade font-mono text-[13px] tracking-[0.18em] uppercase text-[#22ABCF] mb-7\" data-kid=\"7\">(02) — En qué creemos</div>\n\n        <h2 class=\"text-[clamp(2.1rem,3.5vw,3.3rem)] font-semibold tracking-[-0.04em] leading-[1.08]\" data-kid=\"8\">\n          <span class=\"block overflow-hidden\" data-kid=\"9\"><span class=\"line inline-block pb-[0.1em]\" data-kid=\"10\">En un mundo de</span></span>\n          <span class=\"block overflow-hidden\" data-kid=\"11\"><span class=\"line inline-block pb-[0.1em]\" data-kid=\"12\">ruido digital,</span></span>\n          <span class=\"block overflow-hidden\" data-kid=\"13\"><span class=\"line inline-block pb-[0.1em]\" data-kid=\"14\">creamos <em class=\"italic font-light\" style=\"background:linear-gradient(135deg,#22ABCF 0%,#A077F0 100%);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;color:transparent\" data-kid=\"15\">señal.</em></span></span>\n        </h2>\n\n        <p class=\"head-fade mt-7 text-[#A8A8C0] text-base md:text-[1.06rem] leading-relaxed max-w-[44ch]\" data-kid=\"16\">\n          Cortamos el caos con claridad estratégica y coraje creativo — convirtiendo espectadores pasivos en participantes activos del recorrido de tu marca.\n        </p>\n\n        <button type=\"button\" class=\"signal-cta head-fade group mt-9 inline-flex items-center gap-4 text-white\" data-kid=\"17\">\n          <span class=\"text-[0.95rem] font-medium tracking-[-0.01em]\" data-kid=\"18\">Iniciar un proyecto</span>\n          <span class=\"cta-circle inline-flex items-center justify-center w-11 h-11 rounded-full border border-[rgba(255,255,255,0.2)] text-white\" data-kid=\"19\">\n            <svg class=\"cta-arrow w-[18px] h-[18px]\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"20\">\n              <path d=\"M7 17 17 7\" data-kid=\"21\"></path><path d=\"M9 7h8v8\" data-kid=\"22\"></path>\n            </svg>\n          </span>\n        </button>\n      </div>\n\n      \n      <div class=\"cards-col lg:col-span-7 flex flex-col gap-4 md:gap-5\" data-kid=\"23\">\n\n        \n        <div class=\"card-reveal\" data-kid=\"24\">\n          <article class=\"principle-card group/card relative overflow-hidden rounded-2xl bg-[#0d0f0e] border border-[rgba(255,255,255,0.1)] p-7 md:p-9\" data-kid=\"25\">\n            <div class=\"card-glow pointer-events-none absolute inset-0 opacity-0\" style=\"background:radial-gradient(120% 130% at 0% 0%,rgba(34,171,207,0.12),transparent 55%),radial-gradient(120% 130% at 100% 100%,rgba(160,119,240,0.12),transparent 55%)\" data-kid=\"26\"></div>\n            <span class=\"pointer-events-none absolute top-5 right-7 text-[3.4rem] leading-none font-semibold tracking-[-0.05em] text-white/[0.055] select-none\" data-kid=\"27\">01</span>\n            <div class=\"relative z-10\" data-kid=\"28\">\n              <div class=\"card-icon inline-flex items-center justify-center w-12 h-12 rounded-xl border border-[rgba(255,255,255,0.12)] text-[#22ABCF]\" data-kid=\"29\">\n                <svg class=\"w-6 h-6\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"30\">\n                  <circle cx=\"12\" cy=\"12\" r=\"2\" data-kid=\"31\"></circle><path d=\"M7 7a7 7 0 0 0 0 10M17 7a7 7 0 0 1 0 10\" data-kid=\"32\"></path><path d=\"M4 4a11 11 0 0 0 0 16M20 4a11 11 0 0 1 0 16\" data-kid=\"33\"></path>\n                </svg>\n              </div>\n              <h3 class=\"mt-6 text-xl md:text-[1.4rem] font-semibold tracking-[-0.02em]\" data-kid=\"34\">Señal sobre ruido</h3>\n              <div class=\"card-underline mt-3 h-[2px] w-16 origin-left rounded-full bg-[linear-gradient(90deg,#22ABCF,#A077F0)]\" data-kid=\"35\"></div>\n              <p class=\"mt-4 text-sm md:text-[0.97rem] text-[#A8A8C0] leading-relaxed max-w-[48ch]\" data-kid=\"36\">Menos, pero más claro. Priorizamos lo que de verdad mueve la aguja.</p>\n            </div>\n          </article>\n        </div>\n\n        \n        <div class=\"card-reveal\" data-kid=\"37\">\n          <article class=\"principle-card relative overflow-hidden rounded-2xl bg-[#0d0f0e] border border-[rgba(255,255,255,0.1)] p-7 md:p-9\" data-kid=\"38\">\n            <div class=\"card-glow pointer-events-none absolute inset-0 opacity-0\" style=\"background:radial-gradient(120% 130% at 0% 0%,rgba(34,171,207,0.12),transparent 55%),radial-gradient(120% 130% at 100% 100%,rgba(160,119,240,0.12),transparent 55%)\" data-kid=\"39\"></div>\n            <span class=\"pointer-events-none absolute top-5 right-7 text-[3.4rem] leading-none font-semibold tracking-[-0.05em] text-white/[0.055] select-none\" data-kid=\"40\">02</span>\n            <div class=\"relative z-10\" data-kid=\"41\">\n              <div class=\"card-icon inline-flex items-center justify-center w-12 h-12 rounded-xl border border-[rgba(255,255,255,0.12)] text-[#22ABCF]\" data-kid=\"42\">\n                <svg class=\"w-6 h-6\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"43\">\n                  <circle cx=\"12\" cy=\"12\" r=\"8\" data-kid=\"44\"></circle><circle cx=\"12\" cy=\"12\" r=\"3.4\" data-kid=\"45\"></circle><path d=\"M12 2v3M12 19v3M2 12h3M19 12h3\" data-kid=\"46\"></path>\n                </svg>\n              </div>\n              <h3 class=\"mt-6 text-xl md:text-[1.4rem] font-semibold tracking-[-0.02em]\" data-kid=\"47\">Claridad estratégica</h3>\n              <div class=\"card-underline mt-3 h-[2px] w-16 origin-left rounded-full bg-[linear-gradient(90deg,#22ABCF,#A077F0)]\" data-kid=\"48\"></div>\n              <p class=\"mt-4 text-sm md:text-[0.97rem] text-[#A8A8C0] leading-relaxed max-w-[48ch]\" data-kid=\"49\">Cada decisión técnica responde a un objetivo de negocio concreto.</p>\n            </div>\n          </article>\n        </div>\n\n        \n        <div class=\"card-reveal\" data-kid=\"50\">\n          <article class=\"principle-card relative overflow-hidden rounded-2xl bg-[#0d0f0e] border border-[rgba(255,255,255,0.1)] p-7 md:p-9\" data-kid=\"51\">\n            <div class=\"card-glow pointer-events-none absolute inset-0 opacity-0\" style=\"background:radial-gradient(120% 130% at 0% 0%,rgba(34,171,207,0.12),transparent 55%),radial-gradient(120% 130% at 100% 100%,rgba(160,119,240,0.12),transparent 55%)\" data-kid=\"52\"></div>\n            <span class=\"pointer-events-none absolute top-5 right-7 text-[3.4rem] leading-none font-semibold tracking-[-0.05em] text-white/[0.055] select-none\" data-kid=\"53\">03</span>\n            <div class=\"relative z-10\" data-kid=\"54\">\n              <div class=\"card-icon inline-flex items-center justify-center w-12 h-12 rounded-xl border border-[rgba(255,255,255,0.12)] text-[#22ABCF]\" data-kid=\"55\">\n                <svg class=\"w-6 h-6\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"56\">\n                  <path d=\"M13 2 4 14h7l-1 8 9-12h-7z\" data-kid=\"57\"></path>\n                </svg>\n              </div>\n              <h3 class=\"mt-6 text-xl md:text-[1.4rem] font-semibold tracking-[-0.02em]\" data-kid=\"58\">Coraje creativo</h3>\n              <div class=\"card-underline mt-3 h-[2px] w-16 origin-left rounded-full bg-[linear-gradient(90deg,#22ABCF,#A077F0)]\" data-kid=\"59\"></div>\n              <p class=\"mt-4 text-sm md:text-[0.97rem] text-[#A8A8C0] leading-relaxed max-w-[48ch]\" data-kid=\"60\">Apostamos por ideas valientes, no por lo seguro y olvidable.</p>\n            </div>\n          </article>\n        </div>\n\n        \n        <div class=\"card-reveal\" data-kid=\"61\">\n          <article class=\"principle-card relative overflow-hidden rounded-2xl bg-[#0d0f0e] border border-[rgba(255,255,255,0.1)] p-7 md:p-9\" data-kid=\"62\">\n            <div class=\"card-glow pointer-events-none absolute inset-0 opacity-0\" style=\"background:radial-gradient(120% 130% at 0% 0%,rgba(34,171,207,0.12),transparent 55%),radial-gradient(120% 130% at 100% 100%,rgba(160,119,240,0.12),transparent 55%)\" data-kid=\"63\"></div>\n            <span class=\"pointer-events-none absolute top-5 right-7 text-[3.4rem] leading-none font-semibold tracking-[-0.05em] text-white/[0.055] select-none\" data-kid=\"64\">04</span>\n            <div class=\"relative z-10\" data-kid=\"65\">\n              <div class=\"card-icon inline-flex items-center justify-center w-12 h-12 rounded-xl border border-[rgba(255,255,255,0.12)] text-[#22ABCF]\" data-kid=\"66\">\n                <svg class=\"w-6 h-6\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"67\">\n                  <path d=\"M3 17l6-6 4 4 7-7\" data-kid=\"68\"></path><path d=\"M17 8h4v4\" data-kid=\"69\"></path>\n                </svg>\n              </div>\n              <h3 class=\"mt-6 text-xl md:text-[1.4rem] font-semibold tracking-[-0.02em]\" data-kid=\"70\">Impacto medible</h3>\n              <div class=\"card-underline mt-3 h-[2px] w-16 origin-left rounded-full bg-[linear-gradient(90deg,#22ABCF,#A077F0)]\" data-kid=\"71\"></div>\n              <p class=\"mt-4 text-sm md:text-[0.97rem] text-[#A8A8C0] leading-relaxed max-w-[48ch]\" data-kid=\"72\">Diseño y código que se traducen en métricas reales.</p>\n            </div>\n          </article>\n        </div>\n\n      </div>\n    </div>\n  </div>\n\n  <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"73\"></script>\n  <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"74\"></script>\n  <script data-kid=\"75\">\n    window.addEventListener('load', function () {\n      if (!window.gsap) return;\n      gsap.registerPlugin(ScrollTrigger);\n\n      /* ---------- Hover micro-interactions (user-initiated) ---------- */\n      document.querySelectorAll('.principle-card').forEach(function (card) {\n        var glow = card.querySelector('.card-glow');\n        var icon = card.querySelector('.card-icon');\n        var hov = gsap.timeline({ paused: true });\n        hov.to(card, { y: -6, borderColor: 'rgba(34,171,207,0.55)', duration: 0.32, ease: 'power2.out' }, 0)\n           .to(glow, { autoAlpha: 1, duration: 0.32, ease: 'power2.out' }, 0)\n           .to(icon, { scale: 1.08, color: '#38D4F8', borderColor: 'rgba(34,171,207,0.5)', duration: 0.32, ease: 'power2.out' }, 0);\n        card.addEventListener('pointerenter', function () { hov.play(); });\n        card.addEventListener('pointerleave', function () { hov.reverse(); });\n      });\n\n      var cta = document.querySelector('.signal-cta');\n      if (cta) {\n        var circle = cta.querySelector('.cta-circle');\n        var arrow = cta.querySelector('.cta-arrow');\n        var ct = gsap.timeline({ paused: true });\n        ct.to(circle, { borderColor: 'rgba(34,171,207,0.8)', backgroundColor: 'rgba(34,171,207,0.12)', duration: 0.3, ease: 'power2.out' }, 0)\n          .to(arrow, { x: 3, y: -3, duration: 0.3, ease: 'power2.out' }, 0);\n        cta.addEventListener('pointerenter', function () { ct.play(); });\n        cta.addEventListener('pointerleave', function () { ct.reverse(); });\n      }\n\n      /* ---------- Entrance reveals ---------- */\n      var mm = gsap.matchMedia();\n\n      mm.add('(prefers-reduced-motion: no-preference)', function () {\n        gsap.from('.line', {\n          yPercent: 110, duration: 0.9, ease: 'power3.out', stagger: 0.08,\n          scrollTrigger: { trigger: '.signal-head', start: 'top 85%', toggleActions: 'play none none reverse' }\n        });\n\n        gsap.from('.head-fade', {\n          autoAlpha: 0, y: 18, duration: 0.7, ease: 'power3.out', stagger: 0.12,\n          scrollTrigger: { trigger: '.signal-head', start: 'top 82%', toggleActions: 'play none none reverse' }\n        });\n\n        var cards = gsap.utils.toArray('.card-reveal');\n        var unders = cards.map(function (c) { return c.querySelector('.card-underline'); });\n        var tl = gsap.timeline({ scrollTrigger: { trigger: '.cards-col', start: 'top 85%', toggleActions: 'play none none reverse' } });\n        tl.from(cards, { autoAlpha: 0, y: 28, duration: 0.7, ease: 'power3.out', stagger: 0.12 })\n          .from(unders, { scaleX: 0, duration: 0.6, ease: 'power2.out', stagger: 0.12 }, '-=0.5');\n\n        gsap.to('.head-glow', { xPercent: 14, yPercent: -10, scale: 1.18, duration: 9, ease: 'sine.inOut', repeat: -1, yoyo: true });\n      });\n\n      mm.add('(prefers-reduced-motion: reduce)', function () {\n        gsap.set('.line', { yPercent: 0, autoAlpha: 1 });\n        gsap.set('.head-fade', { autoAlpha: 1, y: 0 });\n        gsap.set('.card-reveal', { autoAlpha: 1, y: 0 });\n        gsap.set('.card-underline', { scaleX: 1 });\n      });\n\n      ScrollTrigger.refresh();\n    });\n  </script>\n</section>",
