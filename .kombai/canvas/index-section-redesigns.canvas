currentColor\" class=\"h-2.5 w-2.5\" data-kid=\"172\"><path d=\"M12 2l2.9 6.6 7.1.6-5.4 4.7 1.6 7L12 17.3 5.8 21l1.6-7L2 9.2l7.1-.6z\" data-kid=\"173\"></path></svg><svg viewBox=\"0 0 24 24\" fill=\"currentColor\" class=\"h-2.5 w-2.5\" data-kid=\"174\"><path d=\"M12 2l2.9 6.6 7.1.6-5.4 4.7 1.6 7L12 17.3 5.8 21l1.6-7L2 9.2l7.1-.6z\" data-kid=\"175\"></path></svg><svg viewBox=\"0 0 24 24\" fill=\"currentColor\" class=\"h-2.5 w-2.5\" data-kid=\"176\"><path d=\"M12 2l2.9 6.6 7.1.6-5.4 4.7 1.6 7L12 17.3 5.8 21l1.6-7L2 9.2l7.1-.6z\" data-kid=\"177\"></path></svg>\n            </div>\n            <div class=\"font-medium leading-[1.05] tracking-[-0.02em] text-xl text-white md:text-2xl\" data-kid=\"178\">UI Award</div>\n            <div class=\"mt-1 font-mono text-[11px] uppercase tracking-[0.14em] text-[#A8A8C0]\" data-kid=\"179\">CSSDA · 2025</div>\n          </div>\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-8 w-8 shrink-0 text-[rgba(255,255,255,0.20)]\" data-kid=\"180\"><rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"2\" data-kid=\"181\"></rect><path d=\"M3 9h18\" data-kid=\"182\"></path><path d=\"M9 21V9\" data-kid=\"183\"></path></svg>\n        </div>\n      </article>\n\n    </div>\n  </div>\n\n  <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"184\"></script>\n  <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"185\"></script>\n  <script data-kid=\"186\">\n    (function () {\n      function init() {\n        if (!window.gsap || !window.ScrollTrigger) return;\n        var gsap = window.gsap;\n        gsap.registerPlugin(window.ScrollTrigger);\n\n        var mm = gsap.matchMedia();\n        mm.add(\n          { reduce: \"(prefers-reduced-motion: reduce)\", full: \"(prefers-reduced-motion: no-preference)\" },\n          function (ctx) {\n            var reduce = ctx.conditions.reduce;\n            var tiles = gsap.utils.toArray(\".tile\");\n            var counters = gsap.utils.toArray(\".counter\");\n\n            if (reduce) {\n              gsap.set(tiles, { autoAlpha: 1, y: 0 });\n              counters.forEach(function (el) { el.textContent = el.getAttribute(\"data-target\"); });\n              return;\n            }\n\n            gsap.set(tiles, { autoAlpha: 0, y: 28 });\n            counters.forEach(function (el) { el.textContent = \"0\"; });\n\n            window.ScrollTrigger.batch(\".tile\", {\n              start: \"top 85%\",\n              onEnter: function (els) {\n                gsap.to(els, { autoAlpha: 1, y: 0, duration: 0.7, ease: \"power3.out\", stagger: { each: 0.06, from: \"start\" }, overwrite: true });\n              },\n              onLeaveBack: function (els) { gsap.set(els, { autoAlpha: 0, y: 28, overwrite: true }); }\n            });\n\n            window.ScrollTrigger.create({\n              trigger: \".bento\",\n              start: \"top 80%\",\n              once: true,\n              onEnter: function () {\n                counters.forEach(function (el) {\n                  var target = parseInt(el.getAttribute(\"data-target\"), 10);\n                  var o = { v: 0 };\n                  gsap.to(o, { v: target, duration: 1.4, ease: \"power2.out\", snap: { v: 1 }, onUpdate: function () { el.textContent = o.v; } });\n                });\n              }\n            });\n\n            gsap.to(\".feature-grad\", { backgroundPosition: \"100% 50%\", duration: 9, ease: \"sine.inOut\", repeat: -1, yoyo: true });\n\n            tiles.forEach(function (tile) {\n              var glow = tile.querySelector(\".glow\");\n              var sc = gsap.to(tile, { scale: 1.02, duration: 0.3, ease: \"power2.out\", paused: true });\n              var bd = tile.getAttribute(\"data-noborder\") ? null : gsap.to(tile, { borderColor: \"rgba(34,171,207,0.55)\", duration: 0.3, ease: \"power2.out\", paused: true });\n              var gl = glow ? gsap.to(glow, { autoAlpha: 1, duration: 0.3, ease: \"power2.out\", paused: true }) : null;\n              tile.addEventListener(\"pointerenter\", function () { sc.play(); if (bd) bd.play(); if (gl) gl.play(); });\n              tile.addEventListener(\"pointerleave\", function () { sc.reverse(); if (bd) bd.reverse(); if (gl) gl.reverse(); });\n            });\n\n            var cta = document.querySelector(\".cta\");\n            if (cta) {\n              var arrow = cta.querySelector(\".arrow\");\n              var at = gsap.to(arrow, { x: 6, duration: 0.3, ease: \"power2.out\", paused: true });\n              var cb = gsap.to(cta, { backgroundColor: \"rgba(255,255,255,0.07)\", borderColor: \"rgba(34,171,207,0.55)\", duration: 0.3, ease: \"power2.out\", paused: true });\n              cta.addEventListener(\"pointerenter\", function () { at.play(); cb.play(); });\n              cta.addEventListener(\"pointerleave\", function () { at.reverse(); cb.reverse(); });\n            }\n\n            window.ScrollTrigger.refresh();\n          }\n        );\n      }\n      if (document.readyState === \"complete\") init();\n      else window.addEventListener(\"load\", init);\n    })();\n  </script>\n</section>",
