      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');\n  .awards-v1{font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,Roboto,sans-serif;-webkit-font-smoothing:antialiased;}\n</style>\n\n<section class=\"awards-v1 relative overflow-hidden bg-[#050505] text-white\" data-kid=\"1\">\n  \n  <div aria-hidden=\"true\" class=\"pointer-events-none absolute inset-0 overflow-hidden\" data-kid=\"2\">\n    <div class=\"absolute -top-40 -left-32 h-[44vw] w-[44vw] rounded-full opacity-20 blur-[130px]\" style=\"background:radial-gradient(circle,#22ABCF,transparent 70%)\" data-kid=\"3\"></div>\n    <div class=\"absolute -bottom-48 -right-32 h-[42vw] w-[42vw] rounded-full opacity-20 blur-[130px]\" style=\"background:radial-gradient(circle,#A077F0,transparent 70%)\" data-kid=\"4\"></div>\n  </div>\n\n  <div class=\"relative mx-auto max-w-[1320px] px-6 py-24 md:px-12 md:py-32\" data-kid=\"5\">\n    \n    <div class=\"flex flex-col gap-8 md:flex-row md:items-end md:justify-between\" data-kid=\"6\">\n      <div class=\"max-w-[760px]\" data-kid=\"7\">\n        <div class=\"mb-5 font-mono text-[13px] uppercase tracking-[0.18em] text-[#22ABCF]\" data-kid=\"8\">(01) — Reconocimientos</div>\n        <h2 class=\"font-medium leading-[1.02] tracking-[-0.04em] text-[clamp(2.4rem,5.5vw,4.8rem)]\" data-kid=\"9\">\n          Premios que respaldan<br data-kid=\"10\">\n          <span style=\"background:linear-gradient(135deg,#22ABCF,#A077F0);-webkit-background-clip:text;background-clip:text;color:transparent\" data-kid=\"11\">el trabajo.</span>\n        </h2>\n        <p class=\"mt-6 max-w-[48ch] text-base leading-relaxed text-[#A8A8C0] md:text-lg\" data-kid=\"12\">37 reconocimientos internacionales y locales — y contando.</p>\n      </div>\n\n      \n      <a href=\"#\" class=\"cta inline-flex shrink-0 items-center gap-3 self-start rounded-lg border border-[rgba(255,255,255,0.18)] bg-[rgba(255,255,255,0.02)] px-5 py-3.5 text-sm font-medium text-white md:self-auto\" data-kid=\"13\">\n        <span data-kid=\"14\">Ver todos los premios</span>\n        <span class=\"arrow inline-flex\" data-kid=\"15\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-4 w-4\" data-kid=\"16\"><path d=\"M5 12h14\" data-kid=\"17\"></path><path d=\"m12 5 7 7-7 7\" data-kid=\"18\"></path></svg>\n        </span>\n      </a>\n    </div>\n\n    <div class=\"mt-10 h-px w-full bg-[rgba(255,255,255,0.10)]\" data-kid=\"19\"></div>\n\n    \n    <div class=\"bento mt-10 grid auto-rows-[150px] grid-cols-2 gap-4 md:mt-12 md:auto-rows-[172px] md:grid-cols-4\" data-kid=\"20\">\n\n      \n      <article data-noborder=\"1\" class=\"tile feature relative col-span-2 row-span-2 overflow-hidden rounded-3xl text-[#0a0a14]\" data-kid=\"21\">\n        <div class=\"feature-grad absolute inset-0\" style=\"background-image:linear-gradient(135deg,#22ABCF 0%,#38D4F8 46%,#A077F0 100%);background-size:200% 200%;background-position:0% 50%\" data-kid=\"22\"></div>\n        <span class=\"absolute left-5 top-5 h-5 w-5 border-l-2 border-t-2 border-[#0a0a14]/30\" data-kid=\"23\"></span>\n        <span class=\"absolute bottom-5 right-5 h-5 w-5 border-b-2 border-r-2 border-[#0a0a14]/30\" data-kid=\"24\"></span>\n        <div class=\"relative flex h-full flex-col justify-between p-6 md:p-8\" data-kid=\"25\">\n          <div class=\"flex items-center gap-2 text-[12px] font-semibold uppercase tracking-[0.16em]\" data-kid=\"26\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-5 w-5\" data-kid=\"27\"><path d=\"M6 9H4.5a2.5 2.5 0 0 1 0-5H6\" data-kid=\"28\"></path><path d=\"M18 9h1.5a2.5 2.5 0 0 0 0-5H18\" data-kid=\"29\"></path><path d=\"M4 22h16\" data-kid=\"30\"></path><path d=\"M10 14.66V17c0 .55-.47