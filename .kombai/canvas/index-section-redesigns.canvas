      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');\n  .cap-root{font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif;}\n  .cap-mono{font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;}\n</style>\n\n<section id=\"capacidades\" class=\"cap-root relative overflow-hidden bg-[#050505] text-white\" data-kid=\"1\">\n  \n  <div class=\"pointer-events-none absolute inset-0 overflow-hidden\" aria-hidden=\"true\" data-kid=\"2\">\n    <div class=\"absolute -top-40 -left-32 h-[520px] w-[520px] rounded-full opacity-25 blur-[140px]\" style=\"background:radial-gradient(circle,#22ABCF,transparent 70%)\" data-kid=\"3\"></div>\n    <div class=\"absolute -bottom-44 -right-24 h-[560px] w-[560px] rounded-full opacity-20 blur-[150px]\" style=\"background:radial-gradient(circle,#A077F0,transparent 70%)\" data-kid=\"4\"></div>\n  </div>\n\n  <div class=\"relative z-10 mx-auto max-w-[1320px] px-6 py-24 md:px-12 md:py-32\" data-kid=\"5\">\n    \n    <div class=\"cap-kicker cap-mono text-[13px] uppercase tracking-[0.18em] text-[#38D4F8]\" data-kid=\"6\">(00) — Capacidades</div>\n    <div class=\"mt-5 flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between\" data-kid=\"7\">\n      <h2 class=\"cap-heading max-w-[16ch] text-[clamp(2.5rem,5.6vw,4.9rem)] font-medium leading-[1.02] tracking-[-0.04em]\" data-kid=\"8\">\n        Todo lo que necesitas para <span style=\"background:linear-gradient(135deg,#22ABCF,#A077F0);-webkit-background-clip:text;background-clip:text;color:transparent;\" data-kid=\"9\">escalar.</span>\n      </h2>\n      <p class=\"cap-intro max-w-[42ch] text-[15px] leading-relaxed text-[#A8A8C0] md:text-base lg:text-right\" data-kid=\"10\">\n        Un solo socio para integrar, construir y operar tu stack tecnológico — de la primera línea de código a escala enterprise.\n      </p>\n    </div>\n\n    \n    <div class=\"mt-12 grid grid-cols-1 gap-3 sm:grid-cols-2 md:mt-16 md:gap-4 lg:grid-cols-4 lg:[grid-auto-rows:210px]\" data-kid=\"11\">\n\n      \n      <article class=\"cap-card hero-card group relative flex flex-col justify-between overflow-hidden rounded-[24px] p-7 text-white [will-change:transform] sm:col-span-2 md:p-8 lg:col-start-1 lg:col-end-3 lg:row-start-1 lg:row-end-3\" data-kid=\"12\">\n        <div class=\"hero-grad pointer-events-none absolute inset-0\" style=\"background:linear-gradient(135deg,#22ABCF 0%,#4f9fd6 48%,#A077F0 100%);background-size:200% 200%;\" data-kid=\"13\"></div>\n        <div class=\"pointer-events-none absolute inset-0\" style=\"background:linear-gradient(158deg,rgba(5,5,5,0) 28%,rgba(5,5,5,0.52) 100%)\" data-kid=\"14\"></div>\n        <div class=\"relative z-10 flex items-start justify-between\" data-kid=\"15\">\n          <div class=\"card-icon flex h-12 w-12 items-center justify-center rounded-[12px] border border-white/30 bg-white/10 text-white\" data-kid=\"16\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-6 w-6\" data-kid=\"17\"><circle cx=\"5\" cy=\"6\" r=\"2\" data-kid=\"18\"></circle><circle cx=\"5\" cy=\"18\" r=\"2\" data-kid=\"19\"></circle><circle cx=\"19\" cy=\"12\" r=\"2\" data-kid=\"20\"></circle><path d=\"M7 7l10 4M7 17l10-4\" data-kid=\"21\"></path></svg>\n          </div>\n          <span class=\"cap-mono text-[12px] tracking-[0.1em] text-white/80\" data-kid=\"22\">01</span>\n        </div>\n        <div class=\"relative z-10\" data-kid=\"23\">\n          <div class=\"mb-5 flex flex-wrap gap-2\" data-kid=\"24\">\n            <span class=\"rounded-full border border-white/25 bg-white/10 px-3 py-1 text-[11px] font-medium tracking-wide\" data-kid=\"25\">APIs</span>\n            <span class=\"rounded-full border border-white/25 bg-white/10 px-3 py-1 text-[11px] font-medium tracking-wide\" data-kid=\"26\">Data</span>\n            <span class=\"rounded-full border border-white/25 bg-white/10 px-3 py-1 text-[11px] font-medium tracking-wide\" data-kid=\"27\">Equipos</span>\n          </div>\n          <h3 class=\"text-[clamp(1.9rem,2.4vw,2.6rem)] font-medium leading-[1.05] tracking-[-0.03em]\" data-kid=\"28\">Integración</h3>\n          <p class=\"mt-3 max-w-[34ch] text-[15px] leading-relaxed text-white/85\" data-kid=\"29\">Conectamos sistemas, datos y equipos en una sola capa coherente.</p>\n        </div>\n      </article>\n\n      \n      <article class=\"cap-card group relative flex flex-col overflow-hidden rounded-[16px] border border-[rgba(255,255,255,0.10)] bg-[#0d0f0e] p-6 [will-change:transform] sm:col-span-2 lg:col-start-3 lg:col-end-5 lg:row-start-1 lg:row-end-2\" data-kid=\"30\">\n        <div class=\"card-glow pointer-events-none absolute inset-0\" style=\"background:radial-gradient(120% 130% at 100% 0%,rgba(160,119,240,0.16),transparent 55%)\" data-kid=\"31\"></div>\n        <div class=\"relative z-10 flex h-full flex-col\" data-kid=\"32\">\n          <div class=\"flex items-start justify-between\" data-kid=\"33\">\n            <div class=\"card-icon flex h-11 w-11 items-center justify-center rounded-[10px] border border-[rgba(255,255,255,0.12)] bg-white/[0.03] text-[#38D4F8]\" data-kid=\"34\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-5 w-5\" data-kid=\"35\"><rect x=\"3\" y=\"4\" width=\"18\" height=\"6\" rx=\"1.5\" data-kid=\"36\"></rect><rect x=\"3\" y=\"14\" width=\"18\" height=\"6\" rx=\"1.5\" data-kid=\"37\"></rect><path d=\"M6.5 7h.01M6.5 17h.01\" data-kid=\"38\"></path></svg>\n            </div>\n            <span class=\"cap-mono text-[12px] tracking-[0.1em] text-[#A8A8C0]\" data-kid=\"39\">02</span>\n          </div>\n          <div class=\"mt-auto pt-7\" data-kid=\"40\">\n            <h3 class=\"text-[19px] font-medium leading-tight tracking-[-0.02em] text-white\" data-kid=\"41\">Provisión</h3>\n            <p class=\"mt-2 max-w-[44ch] text-[13.5px] leading-relaxed text-[#A8A8C0]\" data-kid=\"42\">Infraestructura y equipos listos para escalar, cuando los necesitas.</p>\n          </div>\n        </div>\n      </article>\n\n      \n      <article class=\"cap-card group relative flex flex-col overflow-hidden rounded-[16px] border border-[rgba(255,255,255,0.10)] bg-[#0d0f0e] p-6 [will-change:transform] lg:col-start-3 lg:col-end-4 lg:row-start-2 lg:row-end-3\" data-kid=\"43\">\n        <div class=\"card-glow pointer-events-none absolute inset-0\" style=\"background:radial-gradient(120% 120% at 0% 100%,rgba(34,171,207,0.16),transparent 55%)\" data-kid=\"44\"></div>\n        <div class=\"relative z-10 flex h-full flex-col\" data-kid=\"45\">\n          <div class=\"flex items-start justify-between\" data-kid=\"46\">\n            <div class=\"card-icon flex h-11 w-11 items-center justify-center rounded-[10px] border border-[rgba(255,255,255,0.12)] bg-white/[0.03] text-[#38D4F8]\" data-kid=\"47\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-5 w-5\" data-kid=\"48\"><path d=\"M8 7l-4 5 4 5\" data-kid=\"49\"></path><path d=\"M16 7l4 5-4 5\" data-kid=\"50\"></path><path d=\"M13.5 5l-3 14\" data-kid=\"51\"></path></svg>\n            </div>\n            <span class=\"cap-mono text-[12px] tracking-[0.1em] text-[#A8A8C0]\" data-kid=\"52\">03</span>\n          </div>\n          <div class=\"mt-auto pt-7\" data-kid=\"53\">\n            <h3 class=\"text-[19px] font-medium leading-tight tracking-[-0.02em] text-white\" data-kid=\"54\">Desarrollo de soluciones</h3>\n            <p class=\"mt-2 text-[13.5px] leading-relaxed text-[#A8A8C0]\" data-kid=\"55\">Software a medida, de alto rendimiento y bien arquitecturado.</p>\n          </div>\n        </div>\n      </article>\n\n      \n      <article class=\"cap-card group relative flex flex-col overflow-hidden rounded-[16px] border border-[rgba(255,255,255,0.10)] bg-[#0d0f0e] p-6 [will-change:transform] lg:col-start-4 lg:col-end-5 lg:row-start-2 lg:row-end-3\" data-kid=\"56\">\n        <div class=\"card-glow pointer-events-none absolute inset-0\" style=\"background:radial-gradient(120% 120% at 100% 100%,rgba(189,248,213,0.14),transparent 55%)\" data-kid=\"57\"></div>\n        <div class=\"relative z-10 flex h-full flex-col\" data-kid=\"58\">\n          <div class=\"flex items-start justify-between\" data-kid=\"59\">\n            <div class=\"card-icon flex h-11 w-11 items-center justify-center rounded-[10px] border border-[rgba(255,255,255,0.12)] bg-white/[0.03] text-[#38D4F8]\" data-kid=\"60\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-5 w-5\" data-kid=\"61\"><path d=\"M12 3l7 3v5c0 4.4-3 7.6-7 9-4-1.4-7-4.6-7-9V6z\" data-kid=\"62\"></path><path d=\"M9 12l2 2 4-4\" data-kid=\"63\"></path></svg>\n            </div>\n            <span class=\"cap-mono text-[12px] tracking-[0.1em] text-[#A8A8C0]\" data-kid=\"64\">04</span>\n          </div>\n          <div class=\"mt-auto pt-7\" data-kid=\"65\">\n            <h3 class=\"text-[19px] font-medium leading-tight tracking-[-0.02em] text-white\" data-kid=\"66\">Soluciones estables</h3>\n            <p class=\"mt-2 text-[13.5px] leading-relaxed text-[#A8A8C0]\" data-kid=\"67\">Arquitecturas robustas con uptime y soporte continuo.</p>\n          </div>\n        </div>\n      </article>\n\n      \n      <article class=\"cap-card group relative flex flex-col overflow-hidden rounded-[16px] border border-[rgba(255,255,255,0.10)] bg-[#0d0f0e] p-6 [will-change:transform] lg:col-start-1 lg:col-end-2 lg:row-start-3 lg:row-end-4\" data-kid=\"68\">\n        <div class=\"card-glow pointer-events-none absolute inset-0\" style=\"background:radial-gradient(120% 120% at 0% 0%,rgba(34,171,207,0.18),transparent 55%)\" data-kid=\"69\"></div>\n        <div class=\"relative z-10 flex h-full flex-col\" data-kid=\"70\">\n          <div class=\"flex items-start justify-between\" data-kid=\"71\">\n            <div class=\"card-icon flex h-11 w-11 items-center justify-center rounded-[10px] border border-[rgba(255,255,255,0.12)] bg-white/[0.03] text-[#38D4F8]\" data-kid=\"72\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-5 w-5\" data-kid=\"73\"><path d=\"M13 2L4 14h6l-1 8 9-12h-6z\" data-kid=\"74\"></path></svg>\n            </div>\n            <span class=\"cap-mono text-[12px] tracking-[0.1em] text-[#A8A8C0]\" data-kid=\"75\">05</span>\n          </div>\n          <div class=\"mt-auto pt-7\" data-kid=\"76\">\n            <h3 class=\"text-[19px] font-medium leading-tight tracking-[-0.02em] text-white\" data-kid=\"77\">Alto rendimiento</h3>\n            <p class=\"mt-2 text-[13.5px] leading-relaxed text-[#A8A8C0]\" data-kid=\"78\">Optimización end-to-end para velocidad real en producción.</p>\n          </div>\n        </div>\n      </article>\n\n      \n      <article class=\"cap-card group relative flex flex-col overflow-hidden rounded-[16px] border border-[rgba(255,255,255,0.10)] bg-[#0d0f0e] p-6 [will-change:transform] lg:col-start-2 lg:col-end-3 lg:row-start-3 lg:row-end-4\" data-kid=\"79\">\n        <div class=\"card-glow pointer-events-none absolute inset-0\" style=\"background:radial-gradient(120% 120% at 100% 0%,rgba(160,119,240,0.18),transparent 55%)\" data-kid=\"80\"></div>\n        <div class=\"relative z-10 flex h-full flex-col\" data-kid=\"81\">\n          <div class=\"flex items-start justify-between\" data-kid=\"82\">\n            <div class=\"card-icon flex h-11 w-11 items-center justify-center rounded-[10px] border border-[rgba(255,255,255,0.12)] bg-white/[0.03] text-[#38D4F8]\" data-kid=\"83\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-5 w-5\" data-kid=\"84\"><path d=\"M3 16.5l6.5-6.5 5 5L21 7.5\" data-kid=\"85\"></path><path d=\"M15.5 7.5H21V13\" data-kid=\"86\"></path></svg>\n            </div>\n            <span class=\"cap-mono text-[12px] tracking-[0.1em] text-[#A8A8C0]\" data-kid=\"87\">06</span>\n          </div>\n          <div class=\"mt-auto pt-7\" data-kid=\"88\">\n            <h3 class=\"text-[19px] font-medium leading-tight tracking-[-0.02em] text-white\" data-kid=\"89\">Escalabilidad</h3>\n            <p class=\"mt-2 text-[13.5px] leading-relaxed text-[#A8A8C0]\" data-kid=\"90\">Crece sin fricción: de un primer release a escala enterprise.</p>\n          </div>\n        </div>\n      </article>\n\n      \n      <article class=\"cap-card group relative flex flex-col overflow-hidden rounded-[16px] border border-[rgba(255,255,255,0.10)] bg-[#0d0f0e] p-6 [will-change:transform] sm:col-span-2 lg:col-start-3 lg:col-end-5 lg:row-start-3 lg:row-end-4\" data-kid=\"91\">\n        <div class=\"card-glow pointer-events-none absolute inset-0\" style=\"background:radial-gradient(120% 130% at 0% 100%,rgba(34,171,207,0.16),transparent 55%)\" data-kid=\"92\"></div>\n        <div class=\"relative z-10 flex h-full flex-col\" data-kid=\"93\">\n          <div class=\"flex items-start justify-between\" data-kid=\"94\">\n            <div class=\"card-icon flex h-11 w-11 items-center justify-center rounded-[10px] border border-[rgba(255,255,255,0.12)] bg-white/[0.03] text-[#38D4F8]\" data-kid=\"95\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-5 w-5\" data-kid=\"96\"><circle cx=\"9\" cy=\"8\" r=\"3\" data-kid=\"97\"></circle><path d=\"M3.5 20a5.5 5.5 0 0 1 11 0\" data-kid=\"98\"></path><path d=\"M16 5.5a3 3 0 0 1 0 5.8\" data-kid=\"99\"></path><path d=\"M18.5 20a5.5 5.5 0 0 0-2.8-4.8\" data-kid=\"100\"></path></svg>\n            </div>\n            <span class=\"cap-mono text-[12px] tracking-[0.1em] text-[#A8A8C0]\" data-kid=\"101\">07</span>\n          </div>\n          <div class=\"mt-auto pt-7\" data-kid=\"102\">\n            <h3 class=\"text-[19px] font-medium leading-tight tracking-[-0.02em] text-white\" data-kid=\"103\">Compromiso</h3>\n            <p class=\"mt-2 max-w-[46ch] text-[13.5px] leading-relaxed text-[#A8A8C0]\" data-kid=\"104\">Socios tecnológicos a largo plazo, no proveedores de paso.</p>\n          </div>\n        </div>\n      </article>\n\n      \n      <article class=\"cap-card group relative flex overflow-hidden rounded-[16px] border border-[rgba(255,255,255,0.10)] bg-[#0d0f0e] p-6 [will-change:transform] sm:col-span-2 md:p-7 lg:col-start-1 lg:col-end-5 lg:row-start-4 lg:row-end-5\" data-kid=\"105\">\n        <div class=\"card-glow pointer-events-none absolute inset-0\" style=\"background:radial-gradient(90% 200% at 50% 100%,rgba(160,119,240,0.14),rgba(34,171,207,0.10) 40%,transparent 70%)\" data-kid=\"106\"></div>\n        <div class=\"relative z-10 flex w-full flex-col gap-6 md:flex-row md:items-center md:justify-between\" data-kid=\"107\">\n          <div class=\"flex items-start gap-5\" data-kid=\"108\">\n            <div class=\"card-icon flex h-11 w-11 shrink-0 items-center justify-center rounded-[10px] border border-[rgba(255,255,255,0.12)] bg-white/[0.03] text-[#38D4F8]\" data-kid=\"109\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-5 w-5\" data-kid=\"110\"><path d=\"M4 7h7\" data-kid=\"111\"></path><path d=\"M15 7h5\" data-kid=\"112\"></path><path d=\"M4 12h3\" data-kid=\"113\"></path><path d=\"M11 12h9\" data-kid=\"114\"></path><path d=\"M4 17h9\" data-kid=\"115\"></path><path d=\"M17 17h3\" data-kid=\"116\"></path><circle cx=\"13\" cy=\"7\" r=\"2\" data-kid=\"117\"></circle><circle cx=\"9\" cy=\"12\" r=\"2\" data-kid=\"118\"></circle><circle cx=\"15\" cy=\"17\" r=\"2\" data-kid=\"119\"></circle></svg>\n            </div>\n            <div data-kid=\"120\">\n              <div class=\"flex items-center gap-3\" data-kid=\"121\">\n                <span class=\"cap-mono text-[12px] tracking-[0.1em] text-[#A8A8C0]\" data-kid=\"122\">08</span>\n                <h3 class=\"text-[20px] font-medium leading-tight tracking-[-0.02em] text-white\" data-kid=\"123\">Optimización</h3>\n              </div>\n              <p class=\"mt-2 max-w-[60ch] text-[14px] leading-relaxed text-[#A8A8C0]\" data-kid=\"124\">Procesos más ágiles y costos operativos más bajos — medimos, afinamos y repetimos.</p>\n            </div>\n          </div>\n          <a href=\"#contacto\" class=\"inline-flex shrink-0 items-center gap-3 text-[14px] font-medium text-white\" data-kid=\"125\">\n            <span data-kid=\"126\">Hablemos de tu proyecto</span>\n            <span class=\"cta-arrow flex h-9 w-9 items-center justify-center rounded-[8px] border border-[rgba(255,255,255,0.18)] text-[#38D4F8]\" data-kid=\"127\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"h-4 w-4\" data-kid=\"128\"><path d=\"M5 12h14\" data-kid=\"129\"></path><path d=\"M13 6l6 6-6 6\" data-kid=\"130\"></path></svg>\n            </span>\n          </a>\n        </div>\n      </article>\n\n    </div>\n  </div>\n\n  <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"131\"></script>\n  <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"132\"></script>\n  <script data-kid=\"133\">\n    window.addEventListener('load', function () {\n      if (!window.gsap) return;\n      gsap.registerPlugin(ScrollTrigger);\n\n      var mm = gsap.matchMedia();\n      mm.add({ reduce: '(prefers-reduced-motion: reduce)' }, function (ctx) {\n        var reduce = ctx.conditions.reduce;\n\n        if (!reduce) {\n          // header reveal\n          gsap.set(['.cap-kicker', '.cap-heading', '.cap-intro'], { autoAlpha: 0, y: 24 });\n          gsap.timeline({ scrollTrigger: { trigger: '#capacidades', start: 'top 80%', toggleActions: 'play none none reverse' } })\n            .to('.cap-kicker', { autoAlpha: 1, y: 0, duration: 0.5, ease: 'power3.out' })\n            .to('.cap-heading', { autoAlpha: 1, y: 0, duration: 0.7, ease: 'power3.out' }, '-=0.3')\n            .to('.cap-intro', { autoAlpha: 1, y: 0, duration: 0.6, ease: 'power3.out' }, '-=0.45');\n\n          // card reveal (batched)\n          gsap.set('.cap-card', { autoAlpha: 0, y: 28, scale: 0.96 });\n          ScrollTrigger.batch('.cap-card', {\n            start: 'top 85%',\n            onEnter: function (els) { gsap.to(els, { autoAlpha: 1, y: 0, scale: 1, duration: 0.6, stagger: 0.08, ease: 'power3.out', overwrite: true }); },\n            onLeaveBack: function (els) { gsap.to(els, { autoAlpha: 0, y: 28, scale: 0.96, duration: 0.3, stagger: 0.04, overwrite: true }); }\n          });\n        } else {\n          gsap.set(['.cap-kicker', '.cap-heading', '.cap-intro', '.cap-card'], { autoAlpha: 1, y: 0, scale: 1 });\n        }\n\n        // hero gradient drift\n        var hero = document.querySelector('.hero-grad');\n        if (hero && !reduce) {\n          gsap.to(hero, { backgroundPosition: '100% 50%', duration: 14, repeat: -1, yoyo: true, ease: 'sine.inOut' });\n        }\n\n        // per-card hover micro-interactions (GSAP paused tweens)\n        gsap.utils.toArray('.cap-card').forEach(function (card) {\n          var glow = card.querySelector('.card-glow');\n          var icon = card.querySelector('.card-icon');\n          var arrow = card.querySelector('.cta-arrow');\n          if (glow) gsap.set(glow, { autoAlpha: 0 });\n          var tl = gsap.timeline({ paused: true });\n          if (!reduce) tl.to(card, { y: -6, duration: 0.3, ease: 'power2.out' }, 0);\n          if (glow) tl.to(glow, { autoAlpha: 1, duration: 0.3, ease: 'power2.out' }, 0);\n          tl.to(card, { borderColor: 'rgba(34,171,207,0.55)', duration: 0.3, ease: 'power2.out' }, 0);\n          if (icon && !reduce) tl.to(icon, { scale: 1.1, rotation: 6, duration: 0.35, ease: 'back.out(2)' }, 0);\n          if (arrow && !reduce) tl.to(arrow, { x: 4, duration: 0.3, ease: 'power2.out' }, 0);\n          card.addEventListener('pointerenter', function () { tl.play(); });\n          card.addEventListener('pointerleave', function () { tl.reverse(); });\n        });\n\n        ScrollTrigger.refresh();\n      });\n    });\n  </script>\n</section>",
