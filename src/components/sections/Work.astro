---
const businessAreas = [
  {
    title: "Equipamiento",
    description:
      "Ponemos a tu disposición un equipo completo de hardware y soluciones para que tu negocio funcione sin interrupciones.",
    video: "videos_negocio/equipamiento.mp4",
    gridArea: "large",
  },
  {
    title: "Outsourcing y Leasing",
    description:
      "Optimiza tu inversión con alquiler de portátiles, desktops y equipos de TI sin comprometer el rendimiento.",
    video: "videos_negocio/outsourcing_leasing.mp4",
    gridArea: "tall",
  },
  {
    title: "Servicios profesionales",
    description:
      "Servicios expertos diseñados para ayudarte a alcanzar tus metas tecnológicas y de negocio.",
    video: "videos_negocio/servicios_profesionales.mp4",
    gridArea: "small1",
  },
  {
    title: "Ciberseguridad",
    description:
      "Protege la continuidad de tu negocio y la confianza de tus clientes con soluciones de ciberseguridad integrales.",
    video: "videos_negocio/Ciberseguridad.mp4",
    gridArea: "small2",
  },
  {
    title: "Software",
    description:
      "Soluciones de software a medida para optimizar procesos y potenciar tu productividad.",
    video: "videos_negocio/software.mp4",
    gridArea: "small3",
  },
  {
    title: "Soluciones Cloud",
    description: "Acelera tu transformación digital con infraestructura cloud segura y escalable.",
    video: "videos_negocio/soluciones_cloud.mp4",
    gridArea: "small4",
  },
  {
    title: "Infraestructura de Tecnología",
    description: "Moderniza tu infraestructura con redes, soporte y servicios especializados.",
    video: "videos_negocio/infraestructura_de_tecnologia.mp4",
    gridArea: "small5",
  },
  {
    title: "Mantenimiento de equipos",
    description:
      "Asegura la continuidad operativa con mantenimiento preventivo y soporte técnico proactivo.",
    video: "videos_negocio/mantenimiento_equipos.mp4",
    gridArea: "small6",
  },
];
---

<section class="section" id="work">
  <div class="wrap">
    <h2 class="section-title" data-reveal>Áreas de negocio</h2>
  </div>
  <div class="mosaic-wrap">
    <div class="cards-grid" data-work-grid>
      {
        businessAreas.map((item) => (
          <article class="work-card" data-work-card style={`grid-area: ${item.gridArea}`}>
            <video src={`/${item.video}`} poster={`/videos_negocio/posters/${item.video.replace("videos_negocio/", "").replace(".mp4", ".jpg")}`} muted loop playsinline preload="none" class="video-bg" />
            <div class="card-overlay">
              <span class="card-eyebrow">Área de negocio</span>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .section {
    padding-block: clamp(72px, 11vw, 150px);
    position: relative;
  }
  .mosaic-wrap {
    width: 100%;
    padding-inline: clamp(20px, 5vw, 40px);
  }
  .cards-grid {
    display: grid;
    gap: 1rem;
    max-width: 78%;
    margin-inline: auto;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-template-rows: repeat(4, minmax(240px, auto));
    grid-template-areas:
      "large large tall"
      "large large tall"
      "small1 small2 small3"
      "small4 small5 small6";
  }
  .work-card {
    position: relative;
    overflow: hidden;
    border-radius: 28px;
    min-height: 260px;
    background: #0f0f0f;
    transition:
      transform 0.35s ease,
      filter 0.35s ease,
      opacity 0.35s ease,
      box-shadow 0.35s ease;
    content-visibility: auto;
    contain: content;
  }
  .work-card.active {
    transform: scale(1.04);
    z-index: 2;
    box-shadow: 0 36px 80px rgba(0, 0, 0, 0.35);
  }
  .cards-grid.has-hover .work-card:not(.active) {
    opacity: 0.35;
    transform: scale(0.97);
  }
  .work-card[style] {
    display: block;
  }
  .video-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.08);
    transition:
      filter 0.35s ease,
      transform 0.45s ease;
  }
  @media (hover: hover) {
    .video-bg {
      filter: grayscale(100%) contrast(1.05) brightness(0.62);
    }
  }
  .work-card.active .video-bg {
    filter: grayscale(0%) contrast(1.05) brightness(0.92);
    transform: scale(1.12);
    will-change: transform, filter;
  }
  .card-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(1.25rem, 2vw, 2rem);
    background: linear-gradient(180deg, transparent 40%, rgba(0, 0, 0, 0.55) 100%);
  }
  .card-eyebrow {
    color: rgba(255, 255, 255, 0.74);
    font-size: clamp(0.675rem, 0.9vw, 0.81rem);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
    display: inline-block;
  }
  .card-overlay h3 {
    margin: 0;
    color: #fff;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(1.395rem, 2.07vw, 2.52rem);
    line-height: 1.05;
  }
  .card-overlay p {
    margin: 1rem 0 0;
    color: rgba(255, 255, 255, 0.8);
    font-family: var(--font-sans);
    font-size: clamp(0.81rem, 0.9vw, 0.9rem);
    line-height: 1.6;
    max-width: 40rem;
  }
  .section-title {
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.5;
    font-size: clamp(2.4rem, 6.5vw, 5.5rem);
    margin-bottom: clamp(34px, 5vw, 64px);
    background: linear-gradient(90deg, #22abcf, #f2f0f1, #a077f0);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  @media (max-width: 980px) {
    .cards-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-template-rows: repeat(5, minmax(220px, auto));
      grid-template-areas:
        "large tall"
        "large tall"
        "small1 small2"
        "small3 small4"
        "small5 small6";
    }
  }
  @media (max-width: 640px) {
    .cards-grid {
      grid-template-columns: 1fr;
      grid-template-rows: none;
      grid-template-areas:
        "large"
        "tall"
        "small1"
        "small2"
        "small3"
        "small4"
        "small5"
        "small6";
    }
    .work-card {
      min-height: 240px;
    }
  }
</style>

<script>
  const grid = document.querySelector("[data-work-grid]");
  const cards = grid?.querySelectorAll("[data-work-card]");

  cards?.forEach((card) => {
    const video = card.querySelector("video");
    if (!video) return;

    const obs = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          video.preload = "auto";
          video.load();
          obs.unobserve(card);
        }
      },
      { rootMargin: "400px" },
    );
    obs.observe(card);
  });

  cards?.forEach((card) => {
    const video = card.querySelector("video");
    if (!video) return;

    card.addEventListener("mouseenter", () => {
      grid?.classList.add("has-hover");
      cards.forEach((other) => {
        if (other === card) {
          other.classList.add("active");
          other.classList.remove("inactive");
        } else {
          other.classList.remove("active");
          other.classList.add("inactive");
          const otherVideo = other.querySelector("video");
          if (otherVideo) {
            otherVideo.pause();
            otherVideo.currentTime = 0;
          }
        }
      });
      video.currentTime = 0;
      video.play();
    });

    card.addEventListener("mouseleave", () => {
      grid?.classList.remove("has-hover");
      cards.forEach((other) => {
        other.classList.remove("active", "inactive");
        const otherVideo = other.querySelector("video");
        if (otherVideo) {
          otherVideo.pause();
          otherVideo.currentTime = 0;
        }
      });
    });
  });
</script>
