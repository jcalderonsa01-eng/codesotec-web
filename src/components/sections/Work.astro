---
import SectionHeading from "@/components/ui/SectionHeading.astro";
import WorkCard from "@/components/sections/WorkCard.astro";
import { WORK } from "@/data/work";

const total = WORK.length;
---

<section class="section" id="work">
  <div class="wrap">
    <SectionHeading
      index="(01) — Selected Work"
      description="A selection of products, platforms and brands we designed and built end-to-end."
    >
      Things we've<br />made happen
    </SectionHeading>
    <div class="work-grid">
      {WORK.map((item, i) => <WorkCard item={item} index={i} total={total} />)}
    </div>
  </div>
</section>

<style>
  .section {
    padding-block: clamp(72px, 11vw, 150px);
    position: relative;
  }
  .work-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(20px, 2.4vw, 34px);
  }
  @media (max-width: 820px) {
    .work-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
