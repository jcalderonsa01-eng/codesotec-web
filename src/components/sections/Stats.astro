---
import SectionHeading from "@/components/ui/SectionHeading.astro";
import { STATS } from "@/data/stats";
---

<section class="section">
  <div class="wrap">
    <SectionHeading index="(03) — Recognition" description="37 awards and counting across international design competitions and local rankings.">
      Work that gets<br />noticed
    </SectionHeading>
    <div class="stats-grid">
      {STATS.map((stat, i) => (
        <div class="stat" data-reveal data-d={(i % 4) + 1}>
          <div class="num" data-count={stat.value} data-suf={stat.suffix}>0{stat.suffix}</div>
          <div class="lbl">{stat.label}</div>
          <div class="sub">{stat.sub}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section {
    padding-block: clamp(72px, 11vw, 150px);
    position: relative;
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(16px, 2vw, 28px);
  }
  .stat {
    border: 1px solid var(--border-soft);
    border-radius: 16px;
    padding: 30px 26px;
    background: linear-gradient(160deg, var(--color-surface), var(--color-bg));
    transition: 0.45s var(--ease-brand);
  }
  .stat:hover {
    border-color: rgba(62, 192, 145, 0.4);
    transform: translateY(-4px);
  }
  .num {
    font-weight: 900;
    font-size: clamp(2.6rem, 5vw, 3.6rem);
    letter-spacing: -0.04em;
    line-height: 1;
    background: linear-gradient(120deg, var(--color-fg), var(--color-accent-bright));
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .lbl {
    margin-top: 12px;
    color: var(--color-muted);
    font-size: 0.92rem;
    font-weight: 500;
  }
  .sub {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    color: var(--color-faint);
    text-transform: uppercase;
    margin-top: 4px;
  }
  @media (max-width: 1024px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 520px) {
    .stats-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
