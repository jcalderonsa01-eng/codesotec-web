---
import type { Partner } from "@/data/partners";

interface Props {
  partners: Partner[];
}
const { partners } = Astro.props;
---

<section class="partners-stack" data-partners-stack>
  <div class="wrap">
    <div class="stack-head" data-reveal>
      <p class="stack-label">Nuestros Partners</p>
      <h2 class="stack-title">
        Marcas que<br />
        <em class="stack-title-em">respaldan</em> cada proyecto
      </h2>
    </div>
  </div>

  <div class="stack-track wrap">
    {
      partners.map((p, i) => (
        <article
          class="stack-card"
          style={`--i:${i};--accent:${p.accent}`}
          data-stack-card
        >
          <div class="card-inner">
            <span class="card-num">{"0" + (i + 1)}</span>
            <div class="card-body">
              <h3 class="card-name">{p.name}</h3>
              <p class="card-cat">{p.category}</p>
              <p class="card-desc">{p.description}</p>
            </div>
            <div class="card-accent-bar" aria-hidden="true" />
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  .partners-stack {
    padding-block: clamp(80px, 12vw, 140px);
    background: #050505;
  }

  .stack-head {
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  .stack-label {
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .stack-title {
    font-size: clamp(2rem, 5vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.1;
  }

  .stack-title-em {
    font-style: italic;
    font-family: Georgia, "Times New Roman", serif;
    font-weight: 400;
    background: var(--bg-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .stack-track {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .stack-card {
    position: sticky;
    top: calc(80px + var(--i) * 14px);
    background: #111111;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.25rem;
    overflow: hidden;
    will-change: transform;
    min-height: 200px;
  }

  .stack-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 60% 80% at 90% 50%,
      color-mix(in srgb, var(--accent) 10%, transparent),
      transparent 70%
    );
    pointer-events: none;
  }

  .card-inner {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: clamp(1.5rem, 4vw, 3rem);
    padding: clamp(2.5rem, 5vw, 4rem) clamp(1.5rem, 3vw, 2.5rem);
  }

  .card-accent-bar {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--accent);
    border-radius: 0 2px 2px 0;
    opacity: 0.8;
  }

  .card-num {
    font-size: clamp(2.5rem, 6vw, 5.5rem);
    font-weight: 900;
    letter-spacing: -0.05em;
    color: rgba(255, 255, 255, 0.06);
    line-height: 1;
    flex-shrink: 0;
    min-width: 3.5rem;
    user-select: none;
  }

  .card-body {
    flex: 1;
  }

  .card-name {
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 0.25rem;
  }

  .card-cat {
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .card-desc {
    font-size: clamp(0.875rem, 1.2vw, 1rem);
    color: var(--color-muted);
    line-height: 1.7;
    max-width: 56ch;
  }

  @media (max-width: 640px) {
    .card-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }
  }
</style>
