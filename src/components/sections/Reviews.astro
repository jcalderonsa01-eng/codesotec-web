---
import Stars from "@/components/ui/Stars.astro";
import { SITE } from "@/data/site.config";
import { LOGOS } from "@/data/logos";
---

<section class="section" id="culture" style="padding-top:0">
  <div class="wrap">
    <div class="reviews-head" data-reveal>
      <Stars />
      <span class="rv">Reviewed on {SITE.reviews.platform} · {SITE.reviews.count} Reviews</span>
    </div>
    <div class="logos">
      {LOGOS.map((name) => <div class="lg">{name}</div>)}
    </div>
  </div>
</section>

<style>
  .section {
    padding-block: clamp(72px, 11vw, 150px);
    position: relative;
  }
  .reviews-head {
    display: flex;
    align-items: center;
    gap: 18px;
    justify-content: center;
    margin-bottom: 46px;
    flex-wrap: wrap;
  }
  .rv {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.16em;
    color: var(--color-muted);
    text-transform: uppercase;
  }
  .logos {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border-soft);
    border: 1px solid var(--border-soft);
    border-radius: 16px;
    overflow: hidden;
  }
  .lg {
    background: var(--color-bg);
    min-height: 118px;
    display: grid;
    place-items: center;
    font-weight: 600;
    font-size: 1.02rem;
    letter-spacing: -0.02em;
    color: var(--color-faint);
    transition: 0.4s var(--ease-brand);
    text-align: center;
    padding: 16px;
  }
  .lg:hover {
    background: var(--color-surface);
    color: var(--color-fg);
  }
  @media (max-width: 1024px) {
    .logos {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 520px) {
    .logos {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
