---
const items = Array.from({ length: 10 }, () => "Trabajemos juntos").join(" · ");
const track = Array.from({ length: 2 }, () => items).join(" · ");
---

<section class="collab" id="contact">
  <div class="capsule">
    <div class="carousel-track">
      <span set:html={track}></span>
    </div>
  </div>
</section>

<style>
  .collab {
    padding-block: clamp(80px, 12vw, 170px);
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .capsule {
    overflow: hidden;
    white-space: nowrap;
    border-radius: 12px;
    padding: 0 32px;
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: box-shadow 0.4s ease, border-radius 0.4s ease;
    position: relative;
    max-width: 95vw;
  }
  .capsule:hover {
    box-shadow: inset 0 0 50px rgba(160, 119, 240, 0.35);
  }
  .carousel-track {
    display: inline-flex;
    animation: marq 80s linear infinite;
    font-weight: 900;
    font-size: clamp(2.6rem, 9vw, 8rem);
    letter-spacing: -0.04em;
    text-transform: uppercase;
    color: #fff;
    line-height: 1.4;
  }
  @keyframes marq {
    to {
      transform: translateX(-50%);
    }
  }
</style>
