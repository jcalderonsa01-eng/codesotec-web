---
const reviews = [
  {
    name: "Carlos Mendoza",
    company: "TechSolve Group",
    text: "Transformaron nuestra infraestructura digital por completo. El equipo demostró un profesionalismo y una capacidad técnica que superó todas nuestras expectativas.",
    stars: 5,
  },
  {
    name: "Ana Lucía Fernández",
    company: "InnovaCorp",
    text: "La implementación de su software optimizó nuestros procesos en un 40%. Realmente entienden las necesidades del negocio y las traducen en soluciones efectivas.",
    stars: 5,
  },
  {
    name: "Ricardo Paredes",
    company: "GlobalNet Solutions",
    text: "Su servicio de outsourcing nos permitió reducir costos operativos sin sacrificar calidad. Altamente recomendados para cualquier empresa que busque eficiencia.",
    stars: 5,
  },
  {
    name: "María José Castillo",
    company: "DataSmart Analytics",
    text: "La consultoría en ciberseguridad que nos brindaron fue excepcional. Ahora cumplimos con todas las normativas y nuestros clientes confían más en nosotros.",
    stars: 5,
  },
  {
    name: "Andrés Torres",
    company: "CloudFirst Technologies",
    text: "Migrar a la nube con ellos fue una decisión acertada. El proceso fue fluido, transparente y los resultados hablan por sí solos.",
    stars: 5,
  },
  {
    name: "Valentina Ríos",
    company: "EcoSistemas",
    text: "El mantenimiento preventivo que realizan nos ha ahorrado miles de dólares en reparaciones mayores. Su equipo de soporte es rápido y eficiente.",
    stars: 5,
  },
  {
    name: "Diego Herrera",
    company: "PrimeDigit",
    text: "Trabajar con ellos fue una experiencia increíble. No solo cumplieron con los plazos, sino que la calidad del código y la arquitectura superaron lo pactado.",
    stars: 5,
  },
  {
    name: "Gabriela Núñez",
    company: "Nexus Trade",
    text: "Las soluciones cloud que implementaron transformaron nuestra operación. Ahora trabajamos de manera más ágil y con costos reducidos significativamente.",
    stars: 5,
  },
  {
    name: "Fernando Lagos",
    company: "Constructora del Sur",
    text: "Su servicio de leasing de equipos nos permitió acceder a tecnología de punta sin una inversión inicial enorme. Un socio estratégico para cualquier empresa.",
    stars: 5,
  },
  {
    name: "Camila Soto",
    company: "HealthTech Innovations",
    text: "La infraestructura tecnológica que diseñaron para nosotros es robusta, escalable y segura. Han sido fundamentales en nuestro crecimiento.",
    stars: 5,
  },
];

const renderCard = (r: (typeof reviews)[number]) => `
  <div class="review-card">
    <div class="stars">${'<svg viewBox="0 0 24 24" class="star"><path d="M12 2l3 6.9 7.5.6-5.7 5 1.7 7.4L12 18l-6.5 3.9 1.7-7.4L1.5 9.5 9 8.9z"/></svg>'.repeat(r.stars)}</div>
    <p class="review-text">${r.text}</p>
    <div class="review-author">
      <span class="review-name">${r.name}</span>
      <span class="review-company">${r.company}</span>
    </div>
  </div>
`;

const cards = reviews.map(renderCard).join("");
const track = Array.from({ length: 2 }, () => cards).join("");
---

<section class="section" id="reviews">
  <div class="wrap">
    <h1 class="section-title" data-reveal>Las secuelas de lo asombroso</h1>
  </div>
  <div class="carousel-wrap">
    <div class="carousel-track" set:html={track} />
  </div>
</section>

<style>
  .section {
    padding-block: clamp(72px, 11vw, 50px);
    position: relative;
  }
  .section-title {
    font-weight: 900;
    letter-spacing: -0.035em;
    line-height: 1;
    font-size: clamp(2.4rem, 6.5vw, 5.5rem);
    margin-bottom: clamp(34px, 5vw, 64px);
    background: linear-gradient(90deg, #22ABCF, #F2F0F1, #A077F0);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .carousel-wrap {
    width: 100%;
    overflow: hidden;
    padding-inline: clamp(20px, 5vw, 40px);
  }
  .carousel-track {
    display: flex;
    gap: 24px;
    width: max-content;
    animation: scrollReviews 50s linear infinite;
  }
  @keyframes scrollReviews {
    to {
      transform: translateX(-50%);
    }
  }
  :global(.review-card) {
    flex-shrink: 0;
    width: 520px;
    min-height: 260px;
    padding: 32px;
    border: none;
    border-radius: 12px;
    background: #0d0f0e;
    display: flex;
    flex-direction: column;
    position: relative;
  }
  :global(.review-card)::before {
    content: "";
    position: absolute;
    top: -6px;
    left: 20px;
    right: 20px;
    height: 12px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(34, 171, 207, 0.25),
      rgba(160, 119, 240, 0.2),
      transparent
    );
    filter: blur(8px);
    border-radius: 50%;
    pointer-events: none;
  }
  :global(.review-card)::after {
    content: "";
    position: absolute;
    bottom: -6px;
    left: 20px;
    right: 20px;
    height: 12px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(34, 171, 207, 0.25),
      rgba(160, 119, 240, 0.2),
      transparent
    );
    filter: blur(8px);
    border-radius: 50%;
    pointer-events: none;
  }
  :global(.stars) {
    display: flex;
    gap: 2px;
  }
  :global(.star) {
    width: 0.92rem;
    height: 0.92rem;
    fill: #22abcf;
  }
  :global(.review-text) {
    font-size: 0.92rem;
    line-height: 2;
    color: var(--color-text);
    margin: 20px 0 0;
    flex: 1;
  }
  :global(.review-author) {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin-top: 24px;
  }
  :global(.review-name) {
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: -0.02em;
    line-height: 1.6;
  }
  :global(.review-company) {
    font-weight: 700;
    font-size: 0.72rem;
    line-height: 1.6;
    color: #22abcf;
    letter-spacing: 0.08em;
  }
</style>
