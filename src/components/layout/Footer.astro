---
import { SITE } from "@/data/site.config";
---

<footer>
  <div class="wrap">
    <div class="foot-brand">
      <a href="#top" aria-label="Codesotec home">
        <img src="/logo.png" alt="Codesotec" class="foot-logo" />
      </a>
      <div class="foot-columns">
        <div class="foot-col">
          <span class="foot-label">Dirección</span>
          {SITE.address}
        </div>
        <div class="foot-col">
          <span class="foot-label">Teléfonos</span>
          {
            SITE.phones.map((p) => (
              <>
                {p}
                <br />
              </>
            ))
          }
        </div>
        <div class="foot-col">
          <span class="foot-label">Email</span>
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
        </div>
        <div class="foot-col">
          <span class="foot-label">Horario</span>
          {SITE.schedule.split(" · ")[0]}<br />{SITE.schedule.split(" · ")[1]}
        </div>
      </div>
    </div>

    <div class="giant" aria-hidden="true">{SITE.brand.name}</div>

    <div class="foot-bottom">
      <div class="cp">{SITE.copyright}</div>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    background: #050505;
    padding-block: clamp(56px, 8vw, 90px) 36px;
    overflow: hidden;
  }
  .foot-logo {
    height: 34px;
    width: auto;
    display: block;
  }
  .foot-columns {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 60px;
    margin-top: 20px;
    color: var(--color-muted);
    font-size: 0.95rem;
    line-height: 1.9;
  }
  .foot-col {
    display: flex;
    flex-direction: column;
  }
  .foot-label {
    font-weight: 600;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-faint);
    margin-bottom: 6px;
  }
  .foot-col a {
    color: var(--color-muted);
  }
  .foot-col a:hover {
    color: var(--color-accent-bright);
  }

  @media (max-width: 720px) {
    .foot-columns {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 420px) {
    .foot-columns {
      grid-template-columns: 1fr;
    }
  }
  .foot-legal {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    margin-top: 32px;
  }
  .foot-legal a {
    color: var(--color-faint);
    font-size: 0.84rem;
    transition: color 0.3s;
  }
  .foot-legal a:hover {
    color: var(--color-muted);
  }
  .giant {
    font-weight: 900;
    text-align: center;
    letter-spacing: -0.05em;
    line-height: 0.8;
    font-size: clamp(2.6rem, 15vw, 12rem);
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    max-width: 100%;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.16), transparent);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-top: 40px;
    user-select: none;
    pointer-events: none;
  }
  .foot-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    margin-top: clamp(46px, 7vw, 80px);
    padding-top: 26px;
    border-top: 1px solid var(--border-soft);
    flex-wrap: wrap;
  }
  .cp {
    color: var(--color-faint);
    font-size: 0.84rem;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
  }

  @media (max-width: 520px) {
    .foot-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
