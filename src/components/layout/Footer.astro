---
import { SITE, FOOTER_MENU } from "@/data/site.config";
import Brand from "@/components/ui/Brand.astro";

/** Pie del sitio: contacto, columnas de enlaces, wordmark gigante y legal. */
const columns = [
  { title: "Menu", links: FOOTER_MENU },
  { title: "Social", links: SITE.social },
  { title: "Legal", links: SITE.legal },
];
---

<footer>
  <div class="wrap">
    <div class="foot-top">
      <div class="foot-brand">
        <Brand href="#top" large />
        <div class="ci">
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a><br />
          <a href={SITE.phoneHref}>{SITE.phone}</a><br />
          {SITE.address}
        </div>
      </div>

      {
        columns.map((col) => (
          <div class="foot-col">
            <h4>{col.title}</h4>
            <ul>
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    target={link.external ? "_blank" : undefined}
                    rel={link.external ? "noopener noreferrer" : undefined}
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="giant" aria-hidden="true">{SITE.brand.name}</div>

    <div class="foot-bottom">
      <div class="cp">{SITE.copyright}</div>
      <div class="legal">
        {SITE.legal.map((link) => <a href={link.href}>{link.label}</a>)}
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    background: var(--color-bg-2);
    padding-block: clamp(56px, 8vw, 90px) 36px;
    overflow: hidden;
  }
  .foot-top {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: 40px;
  }
  .foot-brand .ci {
    color: var(--color-muted);
    font-size: 0.95rem;
    line-height: 1.9;
    margin-top: 20px;
  }
  .foot-brand .ci a:hover {
    color: var(--color-accent-bright);
  }
  .foot-col h4 {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-faint);
    margin-bottom: 18px;
    font-weight: 600;
  }
  .foot-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 11px;
  }
  .foot-col a {
    color: var(--color-muted);
    font-size: 0.95rem;
    transition: color 0.3s;
    width: fit-content;
  }
  .foot-col a:hover {
    color: var(--color-fg);
  }
  .giant {
    font-weight: 900;
    text-align: center;
    letter-spacing: -0.05em;
    line-height: 0.8;
    font-size: clamp(2.6rem, 15vw, 12rem);
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    max-width: 100%;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.16), transparent);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-top: 40px;
    user-select: none;
    pointer-events: none;
  }
  .foot-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    margin-top: clamp(46px, 7vw, 80px);
    padding-top: 26px;
    border-top: 1px solid var(--border-soft);
    flex-wrap: wrap;
  }
  .legal {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }
  .legal a {
    color: var(--color-faint);
    font-size: 0.84rem;
  }
  .legal a:hover {
    color: var(--color-muted);
  }
  .cp {
    color: var(--color-faint);
    font-size: 0.84rem;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
  }

  @media (max-width: 1024px) {
    .foot-top {
      grid-template-columns: 1fr 1fr;
    }
    .foot-brand {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 520px) {
    .foot-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
