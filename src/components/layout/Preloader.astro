---
import { SITE } from "@/data/site.config";

/** Pantalla de carga. La lógica del % vive en lib/animations/preloader.ts. */
---

<div class="loader" data-preloader>
  <div class="l-inner">
    <div class="l-mark">{SITE.brand.name}</div>
    <div class="l-bar"><i></i></div>
    <div class="l-pct" data-preloader-pct>0%</div>
  </div>
</div>

<style>
  .loader {
    position: fixed;
    inset: 0;
    z-index: 9998;
    background: var(--color-bg);
    display: grid;
    place-items: center;
    transition:
      opacity 0.6s var(--ease-brand),
      visibility 0.6s;
  }
  .loader.done {
    opacity: 0;
    visibility: hidden;
  }
  .l-inner {
    text-align: center;
  }
  .l-mark {
    font-weight: 900;
    font-size: clamp(2rem, 7vw, 4.5rem);
    letter-spacing: -0.04em;
    line-height: 1;
    text-transform: uppercase;
  }
  .l-bar {
    margin: 22px auto 0;
    width: min(60vw, 260px);
    height: 2px;
    background: var(--border);
    overflow: hidden;
    border-radius: 2px;
  }
  .l-bar i {
    display: block;
    height: 100%;
    width: 0;
    background: linear-gradient(90deg, var(--color-accent-deep), var(--color-accent-bright));
    animation: load 2.4s var(--ease-brand) forwards;
  }
  .l-pct {
    margin-top: 14px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: var(--color-faint);
  }
</style>
