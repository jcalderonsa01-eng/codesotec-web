---
import { SITE } from "@/data/site.config";

/** Barra de navegación fija en forma de cápsula centrada. */

const splitLabel = (label: string) => Array.from(label);
const visibleChar = (char: string) => (char === " " ? "\u00A0" : char);
---

<header class="nav" data-nav>
  <!-- Logo: izquierda en modo separado, integrado en modo unificado -->
  <a class="nav-logo" href="#top" aria-label="Codesotec home">
    <img src="/logo.png" alt="Codesotec" />
  </a>

  <!-- Cápsula central con los links de navegación -->
  <div class="nav-capsule">
    <nav class="links">
      {
        SITE.nav.map((link) => (
          <a class="nl" href={link.href} aria-label={link.label}>
            <span class="nl-mask" aria-hidden="true">
              <span class="nl-row nl-row--top">
                {splitLabel(link.label).map((char, index) => (
                  <span class="nl-char" style={`--i: ${index}`}>
                    {visibleChar(char)}
                  </span>
                ))}
              </span>
              <span class="nl-row nl-row--bottom">
                {splitLabel(link.label).map((char, index) => (
                  <span class="nl-char" style={`--i: ${index}`}>
                    {visibleChar(char)}
                  </span>
                ))}
              </span>
            </span>
          </a>
        ))
      }
    </nav>
    <!-- Burger: visible solo en mobile -->
    <div class="burger" data-burger aria-label="Abrir menú">
      <span></span><span></span><span></span>
    </div>
  </div>
</header>

<style>
  /* ── Contenedor principal ─────────────────────────────────────── */
  .nav {
    position: fixed;
    top: 18px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 200;
    width: min(1200px, calc(100% - 36px));
    display: flex;
    align-items: center;
    justify-content: space-between;

    /* Modo separado: sin fondo, solo estructura */
    background: transparent;
    border: 1px solid transparent;
    border-radius: 12px;
    padding: 0;

    transition:
      background 0.45s ease,
      border-color 0.45s ease,
      box-shadow 0.45s ease,
      padding 0.45s ease,
      width 0.45s ease,
      border-radius 0.45s ease;
  }

  /* ── Logo ─────────────────────────────────────────────────────── */
  .nav-logo {
    display: flex;
    align-items: center;
    flex: 0 0 auto;
    transition:
      opacity 0.35s ease,
      margin 0.45s ease,
      padding 0.45s ease,
      border-color 0.45s ease;
  }

  .nav-logo img {
    height: 30px;
    width: auto;
    display: block;
  }

  /* ── Cápsula central ──────────────────────────────────────────── */
  .nav-capsule {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 2px;
    padding: 8px 10px;

    background: rgba(8, 8, 16, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    backdrop-filter: blur(22px);
    -webkit-backdrop-filter: blur(22px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.24);

    transition:
      background 0.45s ease,
      border-color 0.45s ease,
      box-shadow 0.45s ease,
      padding 0.45s ease,
      left 0.45s ease,
      transform 0.45s ease,
      border-radius 0.45s ease;
  }

  /* ── Links ────────────────────────────────────────────────────── */
  .links {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .nl,
  .nl-row--top {
    color: #fff;
  }
  .nl-row--bottom {
    color: #22abcf;
    background-image: linear-gradient(135deg, #22abcf 0%, #a077f0 100%);
    background-clip: text;
    -webkit-background-clip: text;
  }

  .nl {
    position: relative;
    display: inline-flex;
    align-items: center;
    font-size: 0.82rem;
    font-weight: 500;
    color: #22abcf;
    padding: 7px 11px;
    border-radius: 9999px;
    white-space: nowrap;
    transition:
      background 0.2s,
      color 0.2s;
  }

  .nl:hover,
  .nl:focus-visible {
    color: var(--color-fg);
  }

  .nl:focus-visible {
    outline: 1px solid rgba(255, 255, 255, 0.34);
    outline-offset: 3px;
  }

  .nl-mask {
    position: relative;
    display: inline-block;
    height: 1.08em;
    line-height: 1.08;
    overflow: hidden;
  }

  .nl-row {
    display: inline-flex;
    white-space: nowrap;
  }

  .nl-row--bottom {
    position: absolute;
    top: 0;
    left: 0;
    color: var(--color-fg);
  }

  .nl-char {
    display: inline-block;
    transform: translateY(0);
    opacity: 1;
    transition:
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.22s ease;
    transition-delay: calc(var(--i) * 18ms);
    will-change: transform, opacity;
  }

  .nl-row--bottom .nl-char {
    transform: translateY(115%);
    opacity: 0;
  }

  .nl:hover .nl-row--top .nl-char,
  .nl:focus-visible .nl-row--top .nl-char {
    transform: translateY(-115%);
    opacity: 0;
  }

  .nl:hover .nl-row--bottom .nl-char,
  .nl:focus-visible .nl-row--bottom .nl-char {
    transform: translateY(0);
    opacity: 1;
  }

  /* ── Burger ───────────────────────────────────────────────────── */
  .burger {
    display: none;
    flex-direction: column;
    gap: 4px;
    width: 32px;
    height: 32px;
    justify-content: center;
    align-items: center;
    cursor: pointer;
    flex: 0 0 auto;
  }

  .burger span {
    width: 18px;
    height: 2px;
    background: var(--color-fg);
    border-radius: 2px;
    transition: 0.3s var(--ease-brand);
  }

  .burger.x span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .burger.x span:nth-child(2) {
    opacity: 0;
  }
  .burger.x span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* ── Modo UNIFICADO (.unified) ────────────────────────────────── */
  .nav.unified {
    background: rgba(8, 8, 16, 0.72);
    border-color: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(22px);
    -webkit-backdrop-filter: blur(22px);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.28);
    padding: 8px 16px;
    justify-content: center;
    /* Se encoge al contenido en lugar de estirarse al ancho máximo */
    width: fit-content;
    gap: 0;
  }

  /* Logo pasa a flujo normal con separador derecho */
  .nav.unified .nav-logo {
    margin-right: 14px;
    padding-right: 14px;
    border-right: 1px solid rgba(255, 255, 255, 0.12);
  }

  /* La cápsula pierde su propio fondo y posición absoluta */
  .nav.unified .nav-capsule {
    position: relative;
    left: auto;
    transform: none;
    flex: 0 0 auto;
    justify-content: center;
    background: transparent;
    border-color: transparent;
    box-shadow: none;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    padding: 0;
  }

  /* ── Responsive ───────────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .nl {
      font-size: 0.74rem;
      padding: 7px 8px;
    }
  }

  @media (max-width: 820px) {
    /* Separado: solo logo izquierda y burger derecho */
    .links {
      display: none;
    }

    .burger {
      display: flex;
    }

    /* La cápsula solo contiene el burger en mobile */
    .nav-capsule {
      padding: 6px 8px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nl-char {
      transition: none;
    }

    .nl-row--bottom {
      display: none;
    }

    .nl:hover .nl-row--top .nl-char,
    .nl:focus-visible .nl-row--top .nl-char {
      transform: none;
      opacity: 1;
    }
  }
</style>
