---
import { SITE } from "@/data/site.config";

/** Logotipo (glyph + nombre). Reutilizado en Navbar y Footer (DRY). */
interface Props {
  href?: string;
  large?: boolean;
  class?: string;
}
const { href = "#top", large = false, class: className } = Astro.props;
---

<a
  class:list={["brand", { large }, className]}
  href={href}
  aria-label={`${SITE.brand.name} home`}
>
  <span class="glyph" aria-hidden="true"></span>{SITE.brand.name}{
    SITE.brand.suffix && <span class="suffix">{SITE.brand.suffix}</span>
  }
</a>

<style>
  .brand {
    display: flex;
    align-items: center;
    gap: 11px;
    font-weight: 700;
    font-size: 1.06rem;
    letter-spacing: -0.02em;
  }
  .brand.large {
    font-size: 1.4rem;
  }
  .glyph {
    width: 26px;
    height: 26px;
    border-radius: 7px;
    background: conic-gradient(
      from 140deg,
      var(--color-accent),
      var(--color-accent-bright),
      var(--color-accent-glow),
      var(--color-accent)
    );
    display: grid;
    place-items: center;
    flex: 0 0 auto;
    box-shadow: 0 0 22px rgba(34, 171, 207, 0.5);
  }
  .glyph::after {
    content: "";
    width: 9px;
    height: 9px;
    background: var(--color-bg);
    border-radius: 3px;
  }
  .suffix {
    color: var(--color-faint);
    font-weight: 500;
  }
</style>
