---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Productos" description="Descubre los productos y soluciones tecnológicas de Codesotec.">
  <section class="page-section">
    <div class="page-content">
      <h1>Productos</h1>
      <p>
        Ofrecemos un portafolio completo de soluciones TI: desde infraestructura y ciberseguridad hasta
        desarrollo de software a medida y consultoría tecnológica.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .page-section {
    padding: 160px 24px 80px;
    max-width: 800px;
    margin: 0 auto;
    min-height: 60vh;
  }
  .page-content h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 700;
    margin-bottom: 24px;
    letter-spacing: -0.03em;
  }
  .page-content p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--color-muted);
  }
</style>
