---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { NOSOTROS } from "@/data/nosotros";
---

<BaseLayout
  title="Nosotros"
  description="Conoce a Codesotec: más de 5 años impulsando la transformación digital de empresas líderes en Latinoamérica."
>
  <div class="nosotros-scrollytelling-wrapper" data-nosotros-page>
    <div class="scrollytelling-container" data-nosotros-banner>
      <video
        src="/nosotros.mp4"
        muted
        loop
        playsinline
        preload="none"
        class="bg-video"
        data-bg-video
      />
      <div class="bg-overlay-video" aria-hidden="true"></div>

      <!-- Escena 1: Banner principal con Logo + Texto "+5 años contigo" -->
      <div class="scene scene-banner" data-scene="banner">
        <div class="banner-flex" data-banner-flex>
          <div class="logo-box" data-banner-logo>
            <img src={NOSOTROS.banner.logo} alt="Codesotec Logo" />
          </div>
          <h1 class="heading-box" data-banner-heading>
            <span class="heading-plain">+5 años</span>
            <em class="heading-italic">contigo</em>
          </h1>
        </div>
      </div>

      <!-- Escenas: Nosotros Sections (Descripción, Misión, Visión) -->
      {
        NOSOTROS.sections.map((s, idx) => (
          <div class="scene scene-section" data-nosotros-section data-scene={`section-${idx}`}>
            <div class="section-content">
              <h2 class="section-title" data-section-title>
                {s.title}
              </h2>
              <div class="section-body-wrap">
                <p class="section-body" data-section-body>
                  {s.body}
                </p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</BaseLayout>

<style is:global>
  /* Fuerza el fondo negro estático en todo el viewport para la sección Nosotros */
  body:has([data-nosotros-page]) {
    background: #000000 !important;
  }
  body:has([data-nosotros-page]) .bg-overlay {
    display: none !important;
  }
</style>

<style>
  .nosotros-scrollytelling-wrapper {
    width: 100%;
    background: #000000;
    position: relative;
    /* Evita saltos de scroll y overflow horizontal */
    overflow-x: hidden;
  }

  .scrollytelling-container {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #000000;
    overflow: hidden;
  }

  /* Las escenas se apilan perfectamente en el centro */
  .scene {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(1.5rem, 5vw, 4rem);
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 2;
    will-change: opacity, transform, filter;
  }

  .scene-section {
    opacity: 0;
    visibility: hidden;
  }

  .scene-banner {
    visibility: visible !important;
  }

  /* --- Estilos del Banner --- */
  .banner-flex {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(2rem, 5vw, 4.5rem);
    position: relative;
    width: 100%;
    max-width: 1200px;
  }

  .logo-box {
    flex-shrink: 0;
    width: clamp(100px, 15vw, 180px);
    opacity: 0;
    will-change: transform, opacity;
  }

  .logo-box img {
    display: block;
    width: 100%;
    height: auto;
    filter: brightness(0) invert(1);
  }

  .heading-box {
    font-size: clamp(2.5rem, 8vw, 7.5rem);
    line-height: 0.95;
    font-weight: 900;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: #ffffff;
    margin: 0;
    will-change: transform, opacity;
  }

  .heading-plain {
    display: block;
    color: #ffffff;
  }

  .heading-italic {
    font-style: italic;
    font-family: var(--font-serif, Georgia, "Times New Roman", serif);
    font-weight: 400;
    background: var(--bg-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    text-transform: none;
    letter-spacing: 0;
  }

  /* --- Video de fondo --- */
  .bg-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    opacity: 0;
    transition: opacity 0.8s ease;
  }

  .bg-video.playing {
    opacity: 1;
  }

  .bg-overlay-video {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: rgba(0, 0, 0, 0.88);
    pointer-events: none;
  }

  /* --- Estilos de las Secciones (Misión, Visión, Descripción) --- */
  .section-content {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 820px;
    margin: 0 auto;
    text-align: center;
    gap: clamp(1rem, 2.5vw, 2rem);
  }

  .section-title {
    font-size: clamp(3rem, 7vw, 6rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: #ffffff;
    background: linear-gradient(135deg, #ffffff 60%, rgba(255, 255, 255, 0.5));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin: 0;
    will-change: transform, opacity, filter;
  }

  .section-body-wrap {
    position: relative;
    width: 100%;
    max-width: 68ch;
    will-change: transform, opacity, filter;
  }

  .section-body {
    font-size: clamp(1rem, 1.8vw, 1.35rem);
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.85;
    margin: 0 auto;
    letter-spacing: 0.01em;
  }

  /* Responsive para Mobile: stack vertical en el banner */
  @media (max-width: 768px) {
    .banner-flex {
      flex-direction: column;
      gap: 1.5rem;
    }
    .logo-box {
      width: 110px;
    }
    .heading-box {
      text-align: center;
    }
  }

  /* --- Soporte para Reduced Motion: Apilado vertical accesible --- */
  @media (prefers-reduced-motion: reduce) {
    .scrollytelling-container {
      height: auto !important;
      min-height: auto !important;
      overflow: visible !important;
      display: flex !important;
      flex-direction: column !important;
      gap: 5rem !important;
      padding-block: 6rem !important;
    }

    .scene {
      position: relative !important;
      inset: auto !important;
      opacity: 1 !important;
      visibility: visible !important;
      height: auto !important;
      padding: 2rem 1.5rem !important;
      pointer-events: auto !important;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .scene:last-child {
      border-bottom: none;
    }

    .logo-box {
      opacity: 1 !important;
      transform: none !important;
    }

    .heading-box {
      opacity: 1 !important;
      transform: none !important;
    }

    .section-title {
      opacity: 1 !important;
      transform: none !important;
      filter: none !important;
    }

    .section-body-wrap {
      position: relative !important;
      top: auto !important;
      left: auto !important;
      transform: none !important;
      opacity: 1 !important;
      filter: none !important;
      margin-top: 1.5rem !important;
    }

    .bg-video {
      display: none !important;
    }
  }
</style>

<script>
  (() => {
    const video = document.querySelector("[data-bg-video]");
    if (!video) return;
    const start = () => {
      video.play().catch(() => {});
      video.classList.add("playing");
    };
    window.addEventListener("codesotec:loaded", start, { once: true });
    if (document.querySelector(".done")) start();
  })();
</script>
